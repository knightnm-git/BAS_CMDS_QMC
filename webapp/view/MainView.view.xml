
<mvc:View
    controllerName="cos.cmds.qmc.cmdsqmc.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.com.CustomData/1"
    xmlns:smartForm="sap.ui.comp.smartform"
    xmlns:smartField="sap.ui.comp.smartfield"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:l="sap.ui.layout"
    height="100%">

    <ObjectPageLayout id="ObjectPageLayout" showTitleInHeaderContent="false" upperCaseAnchorBar="false">
        
        <headerTitle>
            <ObjectPageDynamicHeaderTitle id="OPDHT1.0">
                <expandedHeading>
                    <m:Title id="Title1.0" text="Cosol - Quick Material Create" wrapping="true"/>
                </expandedHeading>
                <snappedHeading>
                    <m:Title id="Title1.1" text="Cosol - Quick Material Create" wrapping="true"/>
                </snappedHeading>
                    <navigationActions>
                        <m:Button id="Btn1.0"
                          icon="sap-icon://nav-back" 
                          type="Transparent" 
                          press="onNavBack" 
                          tooltip="Back"/>
                          <m:Button 
                            id="btnCreate" 
                            icon="sap-icon://create"
                            text="Create New Material" 
                            type="Emphasized" 
                            press="onCreateMaterial"
                            visible="{= !!${TemplateMat} }" />
                    </navigationActions>

            </ObjectPageDynamicHeaderTitle>
        </headerTitle>

 
        <headerContent>
            <m:VBox id="VB1.0" width="450px" class="sapUiNoContentPadding">
                <m:HBox id="HB1.0" alignItems="Center" class="sapUiTinyMarginBottom">
                    <m:Label id="Lbl1.0" text="Template Material" width="150px" labelFor="materialInput7" />
                    <m:Input
                        id="materialInput7"
                        value="{TemplateMat}"
                        placeholder="Select Material..."
                        showValueHelp="true"
                        valueHelpRequest=".onMaterialValueHelpRequest"
                        change=".onTemplateSelect" />  
                        <m:Button 
                            id="btnReset" 
                            icon="sap-icon://refresh" 
                            type="Transparent" 
                            press="onReset" 
                            tooltip="Clear all data" 
                            class="sapUiTinyMarginBegin" />
                </m:HBox>

                <m:HBox id="HB1.1"  alignItems="Center">
                    <m:Label id="Lbl1.1" text="Test Run" width="150px" />
                    <m:Switch  id="Swtch1.0" state="{/TestRunActive}" customTextOn="Yes" customTextOff="No" />
                </m:HBox>
            </m:VBox>
        </headerContent>



        <sections>
            <ObjectPageSection id="OPS1_MaterialSection" title="Header/Client Data"
            visible="{= !!${TemplateMat} }">
                <subSections>
                    <ObjectPageSubSection id="OPSS1_MaterialSubSection">
                        <f:Form id="F1_MainMaterialForm" editable="true" xmlns:f="sap.ui.layout.form" xmlns:l="sap.ui.layout" xmlns:m="sap.m">
                            <f:layout>
                                <f:ResponsiveGridLayout 
                                    id="RGL1_MainLayout"
                                    labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                    columnsXL="4" columnsL="4" columnsM="2"
                                    emptySpanXL="0" 
                                    emptySpanL="0" 
                                    emptySpanM="0"
                                    adjustLabelSpan="false"
                                    singleContainerFullSize="false" /> 
                            </f:layout>
                            <f:formContainers>
                                
                                <f:FormContainer id="FC1_BasicData">
                                    <f:layoutData>
                                        <l:GridData id="GD_Cont1" span="XL3 L3 M6 S12" />
                                    </f:layoutData>
                                    <f:formElements>
                                    
                                        <f:FormElement id="FE1_Mat" label="Material">
                                            <f:fields><m:Input id="I1_Mat" value="{Matnr}" editable="false" /></f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE1_Desc" label="Description">
                                            <f:fields><m:Input id="I1_MatlDesc" value="{MatlDesc}" /></f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE4_Grp" label="Material Group">
                                            <f:fields>
                                                <m:Input id="I4a_Grp" value="{MatlGroup}" showValueHelp="true" 
                                                         valueHelpRequest="onValueHelpRequest">
                                                    <m:layoutData>
                                                        <l:GridData id="GD4a" span="XL3 L3 M3 S4" />
                                                    </m:layoutData>
                                                    <m:customData>
                                                        <core:CustomData key="entitySet" value="MatGrpVHSet" />
                                                        <core:CustomData key="title" value="Select Material Group" />
                                                        <core:CustomData key="keyField" value="Matkl" /> 
                                                        <core:CustomData key="descField" value="Wgbez" />
                                                        <core:CustomData key="targetDescId" value="I4b_GrpD" />  
                                                    </m:customData>
    
                                                </m:Input>
                                                <m:Input id="I4b_GrpD" value="{MatlGroupDesc}" editable="false" />
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE6_Gross" label="Gross Weight">
                                            <f:fields>
                                                <m:Input id="I6a_GWt" value="{GrossWt}">
                                                    <m:layoutData><l:GridData id="GD6a" span="XL4 L4 M4 S7"/></m:layoutData>
                                                </m:Input>
                                                <m:Input id="I6b_GWtU" value="{UnitOfWt}" showValueHelp="true" 
                                                         valueHelpRequest="onValueHelpRequest">
                                                    <m:layoutData>
                                                        <l:GridData id="GD6b" span="XL2 L2 M2 S3"/>
                                                    </m:layoutData>
                                                    <m:customData>
                                                        <core:CustomData key="entitySet" value="UOMByDimenSet" />
                                                        <core:CustomData key="title" value="Select Weight UOM" />
                                                        <core:CustomData key="keyField" value="Msehi" /> 
                                                        <core:CustomData key="descField" value="Msehl" /> 
                                                    </m:customData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE7_Net" label="Net Weight">
                                            <f:fields>
                                                <m:Input id="I7a_NWt" value="{NetWeight}">
                                                    <m:layoutData><l:GridData id="GD7a" span="XL4 L4 M4 S7"/></m:layoutData>
                                                </m:Input>
                                                <m:Input id="I7b_NWtU" value="{UnitOfWt}">
                                                    <m:layoutData><l:GridData id="GD7b" span="XL2 L2 M2 S3"/></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE8_Vol" label="Volume">
                                            <f:fields>
                                                <m:Input id="I8a_Vol" value="{Volume}">
                                                    <m:layoutData><l:GridData id="GD8a" span="XL4 L4 M4 S7"/></m:layoutData>
                                                </m:Input>
                                                <m:Input id="I8b_VolU" value="{Volumeunit}">
                                                    <m:layoutData><l:GridData id="GD8b" span="XL2 L2 M2 S3"/></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE9_Mfr" label="Manufacturer No">
                                            <f:fields><m:Input id="I9_MfrNo" value="{MfrNo}" /></f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE10_MfrP" label="Manuf. Part No">
                                            <f:fields><m:Input id="I10_ManuMat" value="{ManuMat}" /></f:fields>
                                        </f:FormElement>
                                        
                                    </f:formElements>
                                </f:FormContainer>

                                <f:FormContainer id="FC2">
                                    <f:layoutData>
                                        <l:GridData id="FC2_GD1" span="XL3 L3 M6 S12" />
                                    </f:layoutData>
                                    <f:formElements>
                                        <f:FormElement id="FC2_Fld1" label="Material Type">
                                            <f:fields>
                                            <m:Input id="MatlType" value="{MatlType}" >
                                            <m:layoutData><l:GridData id="GD2_MatType" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FC2_Fld2" label="Base UOM">
                                            <f:fields>
                                                <m:Input id="BaseUom" value="{BaseUom}">
                                                    <m:layoutData><l:GridData id="GD5_Uom" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FC2_Fld3" label="Storage Cond.">
                                            <f:fields><m:Input id="StorConds" value="{StorConds}" >
                                            <m:layoutData><l:GridData id="GD4_Stor" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FC2_Fld4" label="Temp. Cond.">
                                            <f:fields><m:Input id="TempConds" value="{TempConds}" >
                                            <m:layoutData><l:GridData id="FC2_GD4.1" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FC2_Fld5" label="Trans. Group">
                                            <f:fields>
                                                <m:Input id="TransGrp" value="{TransGrp}">
                                                    <m:layoutData><l:GridData id="FC2_GD5.1" span="XL3 L3 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>

                                        <f:FormElement id="FC2_Fld6" label="Division">
                                            <f:fields>
                                                <m:Input id="Division" value="{Division}">
                                                    <m:layoutData><l:GridData id="FC2_GD6.1" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                    <f:FormElement id="FC2_Fld7" label="Label Form">
                                            <f:fields>
                                                <m:Input id="LabelForm" value="{LabelForm}">
                                                    <m:layoutData><l:GridData id="FC2_GD7.1" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>  
                                        <f:FormElement id="FC2_Fld8" label="Container">
                                            <f:fields>
                                                <m:Input id="Container" value="{Container}" >
                                                    <m:layoutData><l:GridData id="FC2_GD8.1" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>                          
                                    </f:formElements>
                                </f:FormContainer>

                                <f:FormContainer id="FC3_Logistics">
                                    <f:layoutData>
                                        <l:GridData id="GD_Cont3" span="XL3 L3 M6 S12" />
                                    </f:layoutData>
                                    <f:formElements>
                                        <f:FormElement id="FE12_PurV" label="Purch.Value Key">
                                            <f:fields>
                                                <m:Input id="I12_PurValkey" value="{PurValkey}">
                                                    <m:layoutData><l:GridData id="GD12_PV" span="XL3 L3 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>

                                        <f:FormElement id="FE19_PSt" label="X-Plant Status">
                                            <f:fields>
                                                <m:Input id="I19_PurStatus" value="{PurStatus}">
                                                    <m:layoutData><l:GridData id="GD19_PS" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                                                <f:FormElement id="FE19_SSt" label="X-DChain Status">
                                            <f:fields>
                                                <m:Input id="I19_SalStatus" value="{SalStatus}">
                                                    <m:layoutData><l:GridData id="GD19_SSt" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE21_MinL" label="Rem. Shelf Life">
                                            <f:fields><m:Input id="I21_Minremlife" value="{Minremlife}" >
                                            <m:layoutData><l:GridData id="GD19_RemSL" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE22_Shelf" label="Total Shelf Life">
                                            <f:fields><m:Input id="I22_ShelfLife" value="{ShelfLife}" >
                                            <m:layoutData><l:GridData id="GD19_TotSL" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                            <f:FormElement id="FE11_Batch" label="Batch Mgmt Rqt">
                                                <f:fields>
                                                    <m:CheckBox id="CB11_BatchMgmt" selected="{BatchMgmt}" />
                                                </f:fields>
                                            </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer>

                            </f:formContainers>
                        </f:Form>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>

            <ObjectPageSection  id="OPS2" title="Plant Data" 
                                visible="{= !!${TemplateMat} }">
                <subSections>
                    <ObjectPageSubSection id="OPSS2">
                        <smartTable:SmartTable  id="STble2"  
                            entitySet="PlantDetailsSet" 
                            tableBindingPath="to_Plants" 
                            header="Plant Details"
                            showRowCount="true" 
                            enableAutoBinding="true"
                            useTablePersonalisation="true"
                            editable="true"
                            editTogglable="true"
                            demandPopin="true"
                            initiallyVisibleFields="CbxCreate,Plant,MrpType,MrpCtrler,PurStatus,ProfitCtr">
                            <m:Table id="Tbl2.1" sticky="ColumnHeaders" />
                        </smartTable:SmartTable>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>

            <ObjectPageSection id="OPS3" title="Valuation Data"
                               visible="{= !!${TemplateMat} }">
                <subSections>
                    <ObjectPageSubSection id="OPSS3">
                        <smartTable:SmartTable  id="STble3" 
                            entitySet="ValuationDetailsSet" 
                            tableBindingPath="to_Valuations" 
                            header="Valuation Areas"
                            enableAutoBinding="true"
                            editable="true"
                            editTogglable="true"
                            useTablePersonalisation="true"
                            demandPopin="true"
                            initiallyVisibleFields="ValArea,ValClass,PriceCtrl,StdPrice,MovingPr">
                            <m:Table id="Tbl3.1" sticky="ColumnHeaders" />
                            </smartTable:SmartTable>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection id="OPS_LongTexts" title="Material Long Texts" visible="{= !!${TemplateMat} }">
                <subSections>
                    <ObjectPageSubSection id="OPSS_LongTexts">
                        <m:VBox id="VB_Texts" class="sapUiSmallMargin">
                            <m:IconTabBar 
                                id="ITB_LongTexts" 
                                expandable="false" 
                                applyContentPadding="false"
                                items="{to_LongTexts}">
                                <m:items>
                                    <m:IconTabFilter 
                                        id="ITF_Dynamic" 
                                        text="{Tdtext}" 
                                        icon="sap-icon://notes">
                                        <m:TextArea 
                                            id="txtDynamicContent" 
                                            value="{TextString}" 
                                            rows="10" 
                                            width="100%" 
                                            growing="true" 
                                            placeholder="Enter text here..." />
                                    </m:IconTabFilter>
                                </m:items>
                            </m:IconTabBar>
                        </m:VBox>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
        </sections>
    </ObjectPageLayout>
</mvc:View>