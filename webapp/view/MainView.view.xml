
<mvc:View
    controllerName="cos.cmds.qmc.cmdsqmc.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.com.CustomData/1"
    xmlns:smartForm="sap.ui.comp.smartform"
    xmlns:smartField="sap.ui.comp.smartfield"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:l="sap.ui.layout"
    height="100%">

    <ObjectPageLayout id="ObjectPageLayout" showTitleInHeaderContent="false" upperCaseAnchorBar="false">
        
        <headerTitle>
            <ObjectPageDynamicHeaderTitle id="OPDHT1.0">
                <expandedHeading>
                    <m:Title id="Title1.0" text="Cosol - Quick Material Create" wrapping="true"/>
                </expandedHeading>
                <snappedHeading>
                    <m:Title id="Title1.1" text="Cosol - Quick Material Create" wrapping="true"/>
                </snappedHeading>
                    <navigationActions>
                        <m:Button id="Btn1.0"
                          icon="sap-icon://nav-back" 
                          type="Transparent" 
                          press="onNavBack" 
                          tooltip="Back"/>
                          <m:Button 
                            id="btnCreate" 
                            icon="sap-icon://create"
                            text="Create New Material" 
                            type="Emphasized" 
                            press="onCreateMaterial"
                            visible="{= !!${TemplateMat} }" />
                    </navigationActions>

            </ObjectPageDynamicHeaderTitle>
        </headerTitle>

 
        <headerContent>
            <m:VBox id="VB1.0" width="450px" class="sapUiNoContentPadding">
                <m:HBox id="HB1.0" alignItems="Center" class="sapUiTinyMarginBottom">
                    <m:Label id="Lbl1.0" text="Template Material" width="150px" labelFor="materialInput7" />
                    <m:Input
                        id="materialInput7"
                        value="{TemplateMat}"
                        editable="{= !${ui>/hasData} &amp;&amp; ${ui>/isCreateMode} }"
                        placeholder="Enter Template Material..."
                        showValueHelp="true"
                        valueHelpRequest=".onMaterialValueHelpRequest"
                        change=".onTemplateSelect" />  
                        <m:Button 
                            id="btnReset" 
                            icon="sap-icon://refresh" 
                            type="Transparent" 
                            press="onReset" 
                            tooltip="Clear all data" 
                            class="sapUiTinyMarginBegin" />
                </m:HBox>

                <m:HBox id="HB1.1"  alignItems="Center">
                    <m:Label id="Lbl1.1" text="Test Run" width="150px" />
                    <m:Switch 
                        id="Swtch1.0" 
                        state="{TestMode}" 
                        customTextOn="Yes" 
                        customTextOff="No" 
                        enabled="{ui>/isCreateMode}" />
                </m:HBox>
            </m:VBox>
        </headerContent>
       <sections>
            <ObjectPageSection id="OPS1_MaterialSection" title="Header/Client Data"
            visible="{= !!${TemplateMat} }">
                <subSections>
                    <ObjectPageSubSection id="OPSS1_MaterialSubSection">
                        <f:Form id="F1_MainMaterialForm" editable="true" xmlns:f="sap.ui.layout.form" xmlns:l="sap.ui.layout" xmlns:m="sap.m">
                            <f:layout>
                                <f:ResponsiveGridLayout 
                                    id="RGL1_MainLayout"
                                    labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                    columnsXL="4" columnsL="4" columnsM="2"
                                    emptySpanXL="0" 
                                    emptySpanL="0" 
                                    emptySpanM="0"
                                    adjustLabelSpan="false"
                                    singleContainerFullSize="false" /> 
                            </f:layout>
                            <f:formContainers>
                                
                                <f:FormContainer id="FC1_BasicData">
                                    <f:layoutData>
                                        <l:GridData id="GD_Cont1" span="XL3 L3 M6 S12" />
                                    </f:layoutData>
                                    <f:formElements>
                                    
                                        <f:FormElement id="FE1_Mat" label="Material">
                                            <f:fields>
                                                <m:Input id="I1_Mat" value="{Matnr}" 
                                                         editable="{= ${fieldControl>/MaterialHeader/Matnr/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/Matnr/required}" 
                                                         visible="{fieldControl>/MaterialHeader/Matnr/visible}"/>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE1_Desc" label="Description">
                                            <f:fields>
                                                <m:Input id="I1_MatlDesc" value="{MatlDesc}" 
                                                         editable="{= ${fieldControl>/MaterialHeader/MatlDesc/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/MatlDesc/required}" 
                                                         visible="{fieldControl>/MaterialHeader/MatlDesc/visible}" />
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE4_Grp" label="Material Group">
                                            <f:fields>
                                                <m:Input id="I4a_Grp" value="{MatlGroup}" 
                                                            showValueHelp="true" 
                                                            valueHelpRequest="onValueHelpRequest"
                                                            editable="{= ${fieldControl>/MaterialHeader/MatlGroup/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                            required="{fieldControl>/MaterialHeader/MatlGroup/required}" 
                                                            visible="{fieldControl>/MaterialHeader/MatlGroup/visible}" >
                                                    <m:layoutData>
                                                        <l:GridData id="GD4a" span="XL3 L3 M3 S4" />
                                                    </m:layoutData>
                                                    <m:customData>
                                                        <core:CustomData key="entitySet" value="MatGrpVHSet" />
                                                        <core:CustomData key="title" value="Select Material Group" />
                                                        <core:CustomData key="useClientSide" value="true" />
                                                        <core:CustomData key="keyField" value="Matkl" /> 
                                                        <core:CustomData key="descField" value="Wgbez" />
                                                        <core:CustomData key="targetDescId" value="I4b_GrpD" />  
                                                    </m:customData>

                                                </m:Input>
                                                <m:Input id="I4b_GrpD" value="{MatlGroupDesc}" editable="false" />
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE6_Gross" label="Gross Weight">
                                            <f:fields>
                                                <m:Input id="I6a_GWt" value="{GrossWt}"
                                                         editable="{= ${fieldControl>/MaterialHeader/GrossWt/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/GrossWt/required}" 
                                                         visible="{fieldControl>/MaterialHeader/GrossWt/visible}" >
                                                    <m:layoutData><l:GridData id="GD6a" span="XL4 L4 M4 S7"/></m:layoutData>
                                                </m:Input>
                                                <m:Input id="I6b_GWtU" value="{UnitOfWt}" showValueHelp="true" 
                                                         valueHelpRequest="onValueHelpRequest"
                                                         editable="{= ${fieldControl>/MaterialHeader/UnitOfWt/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/UnitOfWt/required}" 
                                                         visible="{fieldControl>/MaterialHeader/UnitOfWt/visible}">
                                                    <m:layoutData>
                                                        <l:GridData id="GD6b" span="XL2 L2 M2 S3"/>
                                                    </m:layoutData>
                                                    <m:customData>
                                                        <core:CustomData key="entitySet" value="UOMByDimenSet" />
                                                        <core:CustomData key="title" value="Select Weight UOM" />
                                                        <core:CustomData key="useClientSide" value="false" />
                                                        <core:CustomData key="keyField" value="Msehi" /> 
                                                        <core:CustomData key="descField" value="Msehl" /> 
                                                    </m:customData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE7_Net" label="Net Weight">
                                            <f:fields>
                                                <m:Input id="I7a_NWt" value="{NetWeight}"
                                                         editable="{= ${fieldControl>/MaterialHeader/NetWeight/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/NetWeight/required}" 
                                                         visible="{fieldControl>/MaterialHeader/NetWeight/visible}" >
                                                    <m:layoutData><l:GridData id="GD7a" span="XL4 L4 M4 S7"/></m:layoutData>
                                                </m:Input>
                                                <m:Input id="I7b_NWtU" value="{UnitOfWt}"
                                                         editable="{= ${fieldControl>/MaterialHeader/UnitOfWt/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/UnitOfWt/required}" 
                                                         visible="{fieldControl>/MaterialHeader/UnitOfWt/visible}">
                                                    <m:layoutData><l:GridData id="GD7b" span="XL2 L2 M2 S3"/></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE8_Vol" label="Volume">
                                            <f:fields>
                                                <m:Input id="I8a_Vol" value="{Volume}"
                                                         editable="{= ${fieldControl>/MaterialHeader/Volume/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/Volume/required}" 
                                                         visible="{fieldControl>/MaterialHeader/Volume/visible}" >
                                                    <m:layoutData><l:GridData id="GD8a" span="XL4 L4 M4 S7"/></m:layoutData>
                                                </m:Input>
                                                <m:Input id="I8b_VolU" value="{Volumeunit}"
                                                         editable="{= ${fieldControl>/MaterialHeader/Volumeunit/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/Volumeunit/required}" 
                                                         visible="{fieldControl>/MaterialHeader/Volumeunit/visible}" >
                                                    <m:layoutData><l:GridData id="GD8b" span="XL2 L2 M2 S3"/></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE9_Mfr" label="Manufacturer No">
                                            <f:fields><m:Input id="I9_MfrNo" value="{MfrNo}" 
                                                               editable="{= ${fieldControl>/MaterialHeader/MfrNo/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                               required="{fieldControl>/MaterialHeader/MfrNo/required}" 
                                                               visible="{fieldControl>/MaterialHeader/MfrNo/visible}" /></f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE10_MfrP" label="Manuf. Part No">
                                            <f:fields><m:Input id="I10_ManuMat" value="{ManuMat}" 
                                                               editable="{= ${fieldControl>/MaterialHeader/ManuMat/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                               required="{fieldControl>/MaterialHeader/ManuMat/required}" 
                                                               visible="{fieldControl>/MaterialHeader/ManuMat/visible}"/></f:fields>
                                        </f:FormElement>
                                        
                                    </f:formElements>
                                </f:FormContainer>

                                <f:FormContainer id="FC2">
                                    <f:layoutData>
                                        <l:GridData id="FC2_GD1" span="XL3 L3 M6 S12" />
                                    </f:layoutData>
                                    <f:formElements>
                                        <f:FormElement id="FC2_Fld1" label="Material Type">
                                            <f:fields>
                                            <m:Input id="MatlType" value="{MatlType}" 
                                            editable="{= ${fieldControl>/MaterialHeader/MatlType/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                            required="{fieldControl>/MaterialHeader/MatlType/required}" 
                                            visible="{fieldControl>/MaterialHeader/MatlType/visible}">
                                            <m:layoutData><l:GridData id="GD2_MatType" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FC2_Fld2" label="Base UOM">
                                            <f:fields>
                                                <m:Input id="BaseUom" value="{BaseUom}"
                                                         editable="{= ${fieldControl>/MaterialHeader/BaseUom/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/BaseUom/required}" 
                                                         visible="{fieldControl>/MaterialHeader/BaseUom/visible}">
                                                    <m:layoutData><l:GridData id="GD5_Uom" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FC2_Fld3" label="Storage Cond.">
                                            <f:fields><m:Input id="StorConds" value="{StorConds}" 
                                                               editable="{= ${fieldControl>/MaterialHeader/StorConds/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                               required="{fieldControl>/MaterialHeader/StorConds/required}" 
                                                               visible="{fieldControl>/MaterialHeader/StorConds/visible}">
                                            <m:layoutData><l:GridData id="GD4_Stor" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FC2_Fld4" label="Temp. Cond.">
                                            <f:fields><m:Input id="TempConds" value="{TempConds}" 
                                                               editable="{= ${fieldControl>/MaterialHeader/TempConds/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                               required="{fieldControl>/MaterialHeader/TempConds/required}" 
                                                               visible="{fieldControl>/MaterialHeader/TempCondsvisible}">
                                            <m:layoutData><l:GridData id="FC2_GD4.1" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FC2_Fld5" label="Trans. Group">
                                            <f:fields>
                                                <m:Input id="TransGrp" value="{TransGrp}"
                                                         editable="{= ${fieldControl>/MaterialHeader/TransGrp/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/TransGrp/required}" 
                                                         visible="{fieldControl>/MaterialHeader/TransGrp/visible}">
                                                    <m:layoutData><l:GridData id="FC2_GD5.1" span="XL3 L3 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>

                                        <f:FormElement id="FC2_Fld6" label="Division">
                                            <f:fields>
                                                <m:Input id="Division" value="{Division}"
                                                         editable="{= ${fieldControl>/MaterialHeader/Division/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/Division/required}" 
                                                         visible="{fieldControl>/MaterialHeader/Division/visible}">
                                                    <m:layoutData><l:GridData id="FC2_GD6.1" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                    <f:FormElement id="FC2_Fld7" label="Label Form">
                                            <f:fields>
                                                <m:Input id="LabelForm" value="{LabelForm}"
                                                         editable="{= ${fieldControl>/MaterialHeader/LabelForm/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/LabelForm/required}" 
                                                         visible="{fieldControl>/MaterialHeader/LabelForm/visible}">
                                                    <m:layoutData><l:GridData id="FC2_GD7.1" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>  
                                        <f:FormElement id="FC2_Fld8" label="Container">
                                            <f:fields>
                                                <m:Input id="Container" value="{Container}" 
                                                         editable="{= ${fieldControl>/MaterialHeader/Container/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/Container/required}" 
                                                         visible="{fieldControl>/MaterialHeader/Container/visible}">
                                                    <m:layoutData><l:GridData id="FC2_GD8.1" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>                          
                                    </f:formElements>
                                </f:FormContainer>

                                <f:FormContainer id="FC3_Logistics">
                                    <f:layoutData>
                                        <l:GridData id="GD_Cont3" span="XL3 L3 M6 S12" />
                                    </f:layoutData>
                                    <f:formElements>
                                        <f:FormElement id="FE12_PurV" label="Purch.Value Key">
                                            <f:fields>
                                                <m:Input id="I12_PurValkey" value="{PurValkey}"
                                                         editable="{= ${fieldControl>/MaterialHeader/PurValkey/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/PurValkey/required}" 
                                                         visible="{fieldControl>/MaterialHeader/PurValkey/visible}">
                                                    <m:layoutData><l:GridData id="GD12_PV" span="XL3 L3 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>

                                        <f:FormElement id="FE19_PSt" label="X-Plant Status">
                                            <f:fields>
                                                <m:Input id="I19_PurStatus" value="{PurStatus}"
                                                         editable="{= ${fieldControl>/MaterialHeader/PurStatus/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/PurStatus/required}" 
                                                         visible="{fieldControl>/MaterialHeader/PurStatus/visible}">
                                                    <m:layoutData><l:GridData id="GD19_PS" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                                                <f:FormElement id="FE19_SSt" label="X-DChain Status">
                                            <f:fields>
                                                <m:Input id="I19_SalStatus" value="{SalStatus}"
                                                         editable="{= ${fieldControl>/MaterialHeader/SalStatus/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                         required="{fieldControl>/MaterialHeader/SalStatus/required}" 
                                                         visible="{fieldControl>/MaterialHeader/SalStatus/visible}">
                                                    <m:layoutData><l:GridData id="GD19_SSt" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE21_MinL" label="Rem. Shelf Life">
                                            <f:fields><m:Input id="I21_Minremlife" value="{Minremlife}"
                                                               editable="{= ${fieldControl>/MaterialHeader/Minremlife/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                               required="{fieldControl>/MaterialHeader/Minremlife/required}" 
                                                               visible="{fieldControl>/MaterialHeader/Minremlife/visible}" >
                                            <m:layoutData><l:GridData id="GD19_RemSL" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                        <f:FormElement id="FE22_Shelf" label="Total Shelf Life">
                                            <f:fields><m:Input id="I22_ShelfLife" value="{ShelfLife}" 
                                                               editable="{= ${fieldControl>/MaterialHeader/ShelfLife/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                               required="{fieldControl>/MaterialHeader/ShelfLife/required}" 
                                                               visible="{fieldControl>/MaterialHeader/ShelfLife/visible}">
                                            <m:layoutData><l:GridData id="GD19_TotSL" span="XL2 L2 M3 S4" /></m:layoutData>
                                                </m:Input>
                                            </f:fields>
                                        </f:FormElement>
                                            <f:FormElement id="FE11_Batch" label="Batch Mgmt Rqt">
                                                <f:fields>
                                                    <m:CheckBox id="CB11_BatchMgmt" selected="{BatchMgmt}" 
                                                                editable="{= ${fieldControl>/MaterialHeader/ShelfLife/editable} &amp;&amp; ${ui>/isCreateMode} }" 
                                                                visible="{fieldControl>/MaterialHeader/ShelfLife/visible}"/>
                                                </f:fields>
                                            </f:FormElement>
                                    </f:formElements>
                                </f:FormContainer>

                            </f:formContainers>
                        </f:Form>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>

            <ObjectPageSection  id="OPS2" title="Plant Data" 
                                visible="{= !!${TemplateMat} }">
                <subSections>
                    <ObjectPageSubSection id="OPSS2">
                        <m:Table id="TblPlantDetails" items="{to_Plants}">
                            <m:columns>
                                <m:Column id="colCbxCreate"><m:Text id="lblCbxCreate" text="Create for Plant" /></m:Column>
                                <m:Column id="colPlant"><m:Text id="lblPlant" text="Plant" /></m:Column>
                                <m:Column id="colMrpType"><m:Text id="lblMrpType" text="MRP Type" /></m:Column>
                                <m:Column id="colLotsizekey"><m:Text id="lblLotsizekey" text="Lot Size" /></m:Column>
                                <m:Column id="colMrpCtrler"><m:Text id="lblMrpCtrler" text="MRP Controller" /></m:Column>
                                <m:Column id="colSlocExprc"><m:Text id="lblSlocExprc" text="SLoc Exprc" /></m:Column>
                                <m:Column id="colLgpbe"><m:Text id="lblLgpbe" text="Storage Bin" /></m:Column>
                                <m:Column id="colPurStatus"><m:Text id="lblPurStatus" text="Pur. Status" /></m:Column>
                                <m:Column id="colAbcId"><m:Text id="lblAbcId" text="ABC ID" /></m:Column>
                                <m:Column id="colPurGroup"><m:Text id="lblPurGroup" text="Pur. Group" /></m:Column>
                                <m:Column id="colPlndDelry"><m:Text id="lblPlndDelry" text="Plnd Del. Time" /></m:Column>
                                <m:Column id="colGrPrTime"><m:Text id="lblGrPrTime" text="GR Time" /></m:Column>
                                <m:Column id="colProcType"><m:Text id="lblProcType" text="Proc. Type" /></m:Column>
                                <m:Column id="colSpproctype"><m:Text id="lblSpproctype" text="Spec. Proc" /></m:Column>
                                <m:Column id="colReorderPt"><m:Text id="lblReorderPt" text="Reorder Pt" /></m:Column>
                                <m:Column id="colRoundVal"><m:Text id="lblRoundVal" text="Round Val" /></m:Column>
                                <m:Column id="colBatchMgmt"><m:Text id="lblBatchMgmt" text="Batch Mgmt" /></m:Column>
                                <m:Column id="colAutoPOrd"><m:Text id="lblAutoPOrd" text="Auto PO" /></m:Column>
                                <m:Column id="colProfitCtr"><m:Text id="lblProfitCtr" text="Profit Center" /></m:Column>
                                <m:Column id="colIssStLoc"><m:Text id="lblIssStLoc" text="Issue StLoc" /></m:Column>
                                <m:Column id="colMrpGroup"><m:Text id="lblMrpGroup" text="MRP Group" /></m:Column>
                            </m:columns>
                            <m:items>
                                <m:ColumnListItem id="cliPlant">
                                    <m:cells>
                                        <m:CheckBox id="chkCbxCreate" selected="{CbxCreate}" 
                                                    editable="{path: 'ui>/isCreateMode', formatter: '.formatIsCreateMode'}" />
                                        <m:Input id="iptPlant" value="{Plant}" 
                                                 editable="{parts: [{path: 'fieldControl>/PlantDetails/Plant/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptMrpType" value="{MrpType}" editable="{parts: [{path: 'fieldControl>/PlantDetails/MrpType/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptLotsizekey" value="{Lotsizekey}" editable="{parts: [{path: 'fieldControl>/PlantDetails/Lotsizekey/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptMrpCtrler" value="{MrpCtrler}" editable="{parts: [{path: 'fieldControl>/PlantDetails/MrpCtrler/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptSlocExprc" value="{SlocExprc}" editable="{parts: [{path: 'fieldControl>/PlantDetails/SlocExprc/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptLgpbe" value="{Lgpbe}" editable="{path: 'ui>/isCreateMode', formatter: '.formatIsCreateMode'}" />
                                        <m:Input id="iptPurStatus" value="{PurStatus}" editable="{parts: [{path: 'fieldControl>/PlantDetails/PurStatus/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptAbcId" value="{AbcId}" editable="{parts: [{path: 'fieldControl>/PlantDetails/AbcId/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptPurGroup" value="{PurGroup}" editable="{parts: [{path: 'fieldControl>/PlantDetails/PurGroup/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptPlndDelry" value="{PlndDelry}" editable="{parts: [{path: 'fieldControl>/PlantDetails/PlndDelry/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptGrPrTime" value="{GrPrTime}" editable="{parts: [{path: 'fieldControl>/PlantDetails/GrPrTime/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptProcType" value="{ProcType}" editable="{parts: [{path: 'fieldControl>/PlantDetails/ProcType/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptSpproctype" value="{Spproctype}" editable="{parts: [{path: 'fieldControl>/PlantDetails/Spproctype/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptReorderPt" value="{ReorderPt}" editable="{parts: [{path: 'fieldControl>/PlantDetails/ReorderPt/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptRoundVal" value="{RoundVal}" editable="{parts: [{path: 'fieldControl>/PlantDetails/RoundVal/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:CheckBox id="chkBatchMgmt" selected="{BatchMgmt}" editable="{parts: [{path: 'fieldControl>/PlantDetails/BatchMgmt/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:CheckBox id="chkAutoPOrd" selected="{AutoPOrd}" editable="{parts: [{path: 'fieldControl>/PlantDetails/AutoPOrd/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptProfitCtr" value="{ProfitCtr}" editable="{parts: [{path: 'fieldControl>/PlantDetails/ProfitCtr/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptIssStLoc" value="{IssStLoc}" editable="{parts: [{path: 'fieldControl>/PlantDetails/IssStLoc/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptMrpGroup" value="{MrpGroup}" editable="{parts: [{path: 'fieldControl>/PlantDetails/MrpGroup/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                    </m:cells>
                                </m:ColumnListItem>
                            </m:items>
                        </m:Table>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>

            <ObjectPageSection id="OPS3" title="Valuation Data"
                               visible="{= !!${TemplateMat} }">
                <subSections>
                    <ObjectPageSubSection id="OPSS3">

                        <m:Table id="TblValuation" items="{to_Valuations}">
                            <m:columns>
                                <m:Column id="colValArea"><m:Text id="lblValArea" text="Val. Area" /></m:Column>
                                <m:Column id="colValType"><m:Text id="lblValType" text="Val. Type" /></m:Column>
                                <m:Column id="colValCat"><m:Text id="lblValCat" text="Val. Category" /></m:Column>
                                <m:Column id="colPriceCtrl"><m:Text id="lblPriceCtrl" text="Price Ctrl" /></m:Column>
                                <m:Column id="colStdPrice"><m:Text id="lblStdPrice" text="Std. Price" /></m:Column>
                                <m:Column id="colMovingPr"><m:Text id="lblMovingPr" text="Moving Price" /></m:Column>
                                <m:Column id="colCurrency"><m:Text id="lblCurrency" text="Currency" /></m:Column>
                                <m:Column id="colPriceUnit"><m:Text id="lblPriceUnit" text="Price Unit" /></m:Column>
                                <m:Column id="colValClass"><m:Text id="lblValClass" text="Val. Class" /></m:Column>
                            </m:columns>
                            <m:items>
                                <m:ColumnListItem id="cliValuation">
                                    <m:cells>
                                        <m:Input id="iptValArea" value="{ValArea}" editable="{parts: [{path: 'fieldControl>/ValuationDetails/ValArea/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptValType" value="{ValType}" editable="{parts: [{path: 'fieldControl>/ValuationDetails/ValType/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptValCat" value="{ValCat}" editable="{parts: [{path: 'fieldControl>/ValuationDetails/ValCat/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptPriceCtrl" value="{PriceCtrl}" editable="{parts: [{path: 'fieldControl>/ValuationDetails/PriceCtrl/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptStdPrice" value="{StdPrice}" editable="{parts: [{path: 'fieldControl>/ValuationDetails/StdPrice/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptMovingPr" value="{MovingPr}" editable="{parts: [{path: 'fieldControl>/ValuationDetails/MovingPr/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptCurrency" value="{Currency}" editable="{parts: [{path: 'fieldControl>/ValuationDetails/Currency/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptPriceUnit" value="{PriceUnit}" editable="{parts: [{path: 'fieldControl>/ValuationDetails/PriceUnit/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                        <m:Input id="iptValClass" value="{ValClass}" editable="{parts: [{path: 'fieldControl>/ValuationDetails/ValClass/editable'}, {path: 'ui>/isCreateMode'}], formatter: '.formatCellEditable'}" />
                                    </m:cells>
                                </m:ColumnListItem>
                            </m:items>
                        </m:Table>
                             
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection id="OPS_LongTexts" title="Material Long Texts" visible="{= !!${TemplateMat} }">
                <subSections>
                    <ObjectPageSubSection id="OPSS_LongTexts">
                        <m:VBox id="VB_Texts" class="sapUiSmallMargin">
                            <m:IconTabBar 
                                id="ITB_LongTexts" 
                                expandable="false" 
                                applyContentPadding="false"
                                items="{to_LongTexts}">
                                <m:items>
                                    <m:IconTabFilter 
                                        id="ITF_Dynamic" 
                                        text="{Tdtext}" 
                                        icon="sap-icon://notes">
                                        <m:TextArea 
                                            id="txtDynamicContent" 
                                            value="{TextString}" 
                                            rows="10" 
                                            width="100%" 
                                            growing="true" 
                                            placeholder="Enter text here..." 
                                            editable="{= ${ui>/isCreateMode} }"/>
                                    </m:IconTabFilter>
                                </m:items>
                            </m:IconTabBar>
                        </m:VBox>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
            <ObjectPageSection id="opsRecentMaterials" title="Recent Materials" visible="{= !!${TemplateMat} }">
                <subSections>
                    <ObjectPageSubSection id="opssRecentMaterials">
                        <blocks>
                            <m:Table id="TblRecentMaterials" items="{/xCOSxQMC_I_RECENTMATS}">
                                <m:headerToolbar>
                                    <m:OverflowToolbar id="otbRecentMaterials">
                                        <m:Title id="titRecentMaterials" text="Recently Created Materials" />
                                        <m:ToolbarSpacer id="tspRecentMaterials" />
                                        <m:Button id="btnRefreshRecent" icon="sap-icon://refresh" press="onRefreshRecentTable" />
                                    </m:OverflowToolbar>
                                </m:headerToolbar>
                                <m:columns>
                                    <m:Column id="colRecMat"><m:Text id="lblRecMat" text="Material" /></m:Column>
                                    <m:Column id="colRecType"><m:Text id="lblRecType" text="Mat. Type" /></m:Column>
                                    <m:Column id="colRecDesc"><m:Text id="lblRecDesc" text="Description" /></m:Column>
                                    <m:Column id="colRecUom"><m:Text id="lblRecUom" text="Base UOM" /></m:Column>
                                    <m:Column id="colRecGrp"><m:Text id="lblRecGrp" text="Mat. Group" /></m:Column>
                                    <m:Column id="colRecDate"><m:Text id="lblRecDate" text="Created On" /></m:Column>
                                    <m:Column id="colRecTime"><m:Text id="lblRecTime" text="Time" /></m:Column>
                                </m:columns>
                                <m:items>
                                    <m:ColumnListItem id="cliRecent">
                                        <m:cells>
                                            <m:Text id="txtRecMat" text="{Material}" />
                                            <m:Text id="txtRecType" text="{MatType}" />
                                            <m:Text id="txtRecDesc" text="{Description}" />
                                            <m:Text id="txtRecUom" text="{BaseUOM}" />
                                            <m:Text id="txtRecGrp" text="{MatGroup}" />
                                            <m:Text id="txtRecDate" 
                                                text="{path: 'CreatedOn', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd.MM.yyyy' }}" />
                                            <m:Text id="txtRecTime" 
                                                text="{path: 'CreatedOnTime', formatter: '.formatTime'}" />
                                        </m:cells>
                                    </m:ColumnListItem>
                                </m:items>
                            </m:Table>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
        </sections>
    </ObjectPageLayout>
</mvc:View>